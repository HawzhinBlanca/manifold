# ============================================================================
#  MANIFOLD — Git attributes
#  Consistent line endings for text, Git LFS for Unreal/art/audio binaries.
# ============================================================================

# Normalize line endings; auto-detect text vs binary for anything unlisted.
* text=auto

# --- Source & config: text, normalized to LF in the repo ---
*.cpp        text
*.h          text
*.hpp        text
*.inl        text
*.cs         text
*.md         text
*.txt        text
*.json       text
*.ini        text
*.xml        text
*.yml        text
*.yaml       text
*.uproject   text
*.uplugin    text
*.editorconfig text
.gitattributes text
.gitignore   text

# --- Scripts: pin endings so they run on their target shell ---
*.sh         text eol=lf
*.bat        text eol=crlf
*.cmd        text eol=crlf
*.ps1        text eol=crlf

# ============================================================================
#  Git LFS — Unreal binary assets
#  Requires `git lfs install` once per machine. Content/ is empty today; these
#  rules apply the moment real assets land so they never bloat git history.
# ============================================================================
*.uasset  filter=lfs diff=lfs merge=lfs -text
*.umap    filter=lfs diff=lfs merge=lfs -text
*.ubulk   filter=lfs diff=lfs merge=lfs -text
*.uexp    filter=lfs diff=lfs merge=lfs -text

# --- 3D / textures ---
*.fbx     filter=lfs diff=lfs merge=lfs -text
*.obj     filter=lfs diff=lfs merge=lfs -text
*.png     filter=lfs diff=lfs merge=lfs -text
*.jpg     filter=lfs diff=lfs merge=lfs -text
*.jpeg    filter=lfs diff=lfs merge=lfs -text
*.tga     filter=lfs diff=lfs merge=lfs -text
*.psd     filter=lfs diff=lfs merge=lfs -text
*.exr     filter=lfs diff=lfs merge=lfs -text
*.hdr     filter=lfs diff=lfs merge=lfs -text

# --- Audio / video ---
*.wav     filter=lfs diff=lfs merge=lfs -text
*.mp3     filter=lfs diff=lfs merge=lfs -text
*.ogg     filter=lfs diff=lfs merge=lfs -text
*.flac    filter=lfs diff=lfs merge=lfs -text
*.mp4     filter=lfs diff=lfs merge=lfs -text
*.gif     filter=lfs diff=lfs merge=lfs -text
